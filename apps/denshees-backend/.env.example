# Port the Hono backend server runs on
PORT=8100

# Redis connection (used by BullMQ for job queues)
# In Docker, set REDIS_HOST=redis (the service name)
REDIS_HOST=localhost
REDIS_PORT=6379

# PostgreSQL connection string (Neon, Supabase, or local)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=
