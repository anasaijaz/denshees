# Internal API key for authenticating requests
API_KEY=

# OpenAI API key for AI features (https://platform.openai.com/api-keys)
OPENAI_API_KEY=

# Dodo Payments API key (https://dodopayments.com)
DODO_PAYMENTS_API_KEY=

# Secret used to sign and verify JWT tokens
JWT_SECRET=

# PostgreSQL connection string (Neon, Supabase, or local)
# Example: postgresql://user:password@host:5432/dbname?sslmode=require
DATABASE_URL=

# SMTP credentials for sending emails (e.g., Gmail app password)
SMTP_USER=
SMTP_PASS=

# Comma-separated list of emails that receive support notifications
SUPPORT_NOTIFY_EMAILS=
